<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_expanded_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/floating_expanded_bg"
    android:elevation="12dp">

    <View
        android:id="@+id/floating_drag_handle"
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/floating_handle_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/session_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PhoneClaw"
                android:textColor="@color/floating_text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/session_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前会话"
                android:textColor="@color/floating_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/export_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="@drawable/floating_icon_button_bg"
            android:tint="@color/floating_text_primary"
            android:contentDescription="Export Chat" />

        <ImageButton
            android:id="@+id/screenshot_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/floating_icon_button_bg"
            android:tint="@color/floating_text_primary"
            android:contentDescription="Capture Screen" />

        <ImageButton
            android:id="@+id/new_session_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="@drawable/floating_icon_button_bg"
            android:tint="@color/floating_text_primary"
            android:contentDescription="New Session" />

        <ImageButton
            android:id="@+id/collapse_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/floating_icon_button_bg"
            android:tint="@color/floating_text_primary"
            android:contentDescription="Collapse" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tab_chat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chat"
            android:textColor="@color/floating_accent"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/tab_indicator"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_sessions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sessions"
            android:textColor="@color/floating_text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tab_models"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Models"
            android:textColor="@color/floating_text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/tab_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp">

        <ListView
            android:id="@+id/conversation_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:overScrollMode="never"
            android:stackFromBottom="true"
            android:transcriptMode="normal"
            android:visibility="visible" />

        <ListView
            android:id="@+id/session_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:visibility="gone" />

        <ListView
            android:id="@+id/model_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模型:"
                android:textColor="@color/floating_text_secondary"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/model_spinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:background="@android:color/transparent"
                android:spinnerMode="dropdown" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/floating_input_row_bg"
            android:padding="8dp"
            android:gravity="center_vertical">

        <EditText
            android:id="@+id/message_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入消息..."
            android:textColorHint="@color/floating_text_secondary"
            android:textColor="@color/floating_text_primary"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:textIsSelectable="true"
            android:fontFamily="sans-serif" />

        <ImageButton
            android:id="@+id/voice_input_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/floating_icon_button_bg"
            android:tint="@color/floating_accent"
            android:contentDescription="Voice Input" />

        <Button
            android:id="@+id/send_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/floating_primary_button_bg"
            android:minHeight="36dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="发送"
            android:textColor="@color/black"
            android:fontFamily="sans-serif-medium" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
