<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/message_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/message_bubble_bg"
        android:padding="10dp">

        <LinearLayout
            android:id="@+id/tool_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tool_name_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/floating_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <ProgressBar
                android:id="@+id/tool_progress"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:visibility="visible" />

            <TextView
                android:id="@+id/tool_status_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="14sp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/expand_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/arrow_down_float"
                android:tint="@color/floating_text_secondary"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/message_role_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/floating_accent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/floating_text_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tool_params_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/floating_text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:maxLines="10" />

        <View
            android:id="@+id/tool_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@color/floating_border"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tool_result_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/floating_text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:maxLines="10" />

    </LinearLayout>

</LinearLayout>
